# ─── Google Sheets ───────────────────────────────────────────────
# The ID of your Google Sheet (from the URL: /spreadsheets/d/SPREADSHEET_ID/edit)
SPREADSHEET_ID=your_google_sheet_id_here

# Service Account JSON key (paste the entire JSON content as a single-line string)
# Create at: https://console.cloud.google.com → IAM → Service Accounts → Create Key (JSON)
# Then share your Google Sheet with the service account email (Editor access)
GOOGLE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n","client_email":"...","client_id":"...","auth_uri":"...","token_uri":"..."}

# ─── Telegram ────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=8486884650:AAHYtffxrL3KTWQD_k41olxeYhx8q1w-dtE
TELEGRAM_CHAT_ID=8485267091

# ─── Admin ───────────────────────────────────────────────────────
# Initial admin password (will be stored as SHA-256 hash in Google Sheets Config tab)
ADMIN_PASSWORD=admin123

# ─── Cron Security ───────────────────────────────────────────────
# Secret token to authenticate Vercel cron requests (set this in Vercel dashboard too)
CRON_SECRET=your_random_secret_here

# ─── App ─────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME=NatureFarm
